{
    "bpm": 110,
    "masterDrive": 1.0,
    "instruments": {
        "retro_bass": {
            "fn": "const p1 = (t * frequency) % 1.0; const p2 = (t * (frequency * 1.005)) % 1.0; const saw1 = 2.0 * p1 - 1.0; const saw2 = 2.0 * p2 - 1.0; return (saw1 + saw2) * 0.5;",
            "continuousPhase": false
        },
        "fm_bell": {
            "fn": "const modEnv = Math.exp(-t * 6); const modulator = Math.sin(2 * Math.PI * (frequency * 3.5) * t) * (15 * modEnv); return Math.sin(2 * Math.PI * frequency * t + modulator);",
            "continuousPhase": false
        },
        "pwm_lead": {
            "fn": "const lfo = 0.5 + Math.sin(2 * Math.PI * 4 * t) * 0.3; const square = ((t * frequency) % 1.0) < lfo ? 1.0 : -1.0; return square;",
            "continuousPhase": true
        },
        "kick_drum": {
            "fn": "const pitchEnv = Math.exp(-t * 40); const currentFreq = 45 + 110 * pitchEnv; const click = Math.sin(2 * Math.PI * currentFreq * t); const ampEnv = Math.exp(-t * 8); return click * ampEnv;",
            "continuousPhase": false
        },
        "synthwave_snare": {
            "fn": "const noise = Math.random() * 2.0 - 1.0; const tonalCrack = Math.sin(2 * Math.PI * 180 * t) * Math.exp(-t * 60); const snappyEnv = Math.exp(-t * 15); const tailEnv = Math.exp(-t * 5); return (tonalCrack * 0.4) + (noise * tailEnv * 0.6) * snappyEnv;",
            "continuousPhase": false
        }
    },
